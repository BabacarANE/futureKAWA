# Pays (bresil | equateur | colombie)
PAYS=bresil

# Base de données
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=futurekawa

# MQTT
MQTT_BROKER=mqtt-bresil
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=futurekawa/bresil

# Alerting email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@futurekawa.com
SMTP_PASSWORD=changeme
EMAIL_RESPONSABLE=responsable.bresil@futurekawa.com

# Seuils (injectés par docker-compose selon le pays)
SEUIL_TEMP=29
SEUIL_HUMIDITE=55
TOLERANCE_TEMP=3
TOLERANCE_HUMIDITE=2

# URLs pays (pour backend-siege)
API_BRESIL=http://api-bresil:8000
API_EQUATEUR=http://api-equateur:8000
API_COLOMBIE=http://api-colombie:8000
