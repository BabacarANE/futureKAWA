# ══════════════════════════════════════════════════════════════
#  FutureKawa — Variables d'environnement
#  Copier ce fichier en .env et adapter les valeurs
#  NE PAS committer .env en production (secrets !)
# ══════════════════════════════════════════════════════════════

# ── JWT (même clé sur tous les services) ──────────────────────
SECRET_KEY=changeme-secret-key-min-32-chars

# ── Backend pays (bresil | equateur | colombie) ───────────────
PAYS=bresil

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=futurekawa

# URLs complètes (override auto selon le pays en Docker)
DATABASE_URL=postgresql://postgres:changeme@localhost:5433/futurekawa
# Équateur  : postgresql://postgres:changeme@localhost:5434/futurekawa
# Colombie  : postgresql://postgres:changeme@localhost:5435/futurekawa

# ── MQTT ──────────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=futurekawa/bresil
# Pour dev local sans Docker :
# Brésil    : localhost:1884
# Équateur  : localhost:1885
# Colombie  : localhost:1886

# Seuils IoT par pays (injectés automatiquement par docker-compose)
SEUIL_TEMP=29
SEUIL_HUMIDITE=55
TOLERANCE_TEMP=3
TOLERANCE_HUMIDITE=2

# ── Emails (alertes) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=votre_app_password_gmail
EMAIL_RESPONSABLE=responsable@futurekawa.com

# ── Backend siège — URLs des backends pays ────────────────────
# En Docker (noms de services) :
API_BRESIL=http://api-bresil:8000
API_EQUATEUR=http://api-equateur:8000
API_COLOMBIE=http://api-colombie:8000
# En dev local sans Docker :
# API_BRESIL=http://localhost:8001
# API_EQUATEUR=http://localhost:8002
# API_COLOMBIE=http://localhost:8003

# ── Frontend (Vite) ───────────────────────────────────────────
# URL du backend-siege vue depuis le navigateur
# En dev local : laisser vide (proxy Vite gère via vite.config.ts)
# En production Docker : http://localhost:8000
VITE_API_URL=http://localhost:8000
